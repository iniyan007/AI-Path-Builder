{
  "name": "enterprise-mern-todo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
